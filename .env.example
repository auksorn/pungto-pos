# Neon (or any Postgres) connection string. Pooled endpoint — used by the app at runtime.
DATABASE_URL=postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require

# Direct (non-pooled) endpoint — used only by drizzle-kit for migrations (DDL is safer
# run outside pgbouncer's transaction pooling mode).
DATABASE_URL_UNPOOLED=postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require

# Where uploaded product/ingredient photos are stored (outside the build output so they
# survive `nuxt build`). Defaults to ./data/uploads if unset.
UPLOADS_DIR=./data/uploads

# 32+ char random secret used to encrypt session cookies. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NUXT_SESSION_PASSWORD=
